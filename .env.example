# =====================================================
# MarketPlace 환경 변수 설정
# 이 파일을 복사해 .env로 만들고 실제 값을 입력하세요:
#   cp .env.example .env
# =====================================================

# -------------------
# Java Environment
# Java 17 이상의 JDK 경로를 입력하세요.
# Windows 예: C:\Program Files\Java\jdk-17
# macOS/Linux 예: /usr/lib/jvm/java-17-openjdk
# -------------------
JAVA_HOME=C:\Path\To\Your\JDK-17

# -------------------
# Google OAuth2
# https://console.cloud.google.com/apis/credentials 에서 발급
# OAuth 2.0 클라이언트 ID → 웹 애플리케이션 선택
# 승인된 리디렉션 URI: http://localhost:8080/login/oauth2/code/google
# -------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------------------
# JWT 시크릿
# 32자 이상의 랜덤 문자열 (예: openssl rand -base64 32)
# -------------------
JWT_SECRET=change-me-to-at-least-32-characters-long-random-string

# -------------------
# 데이터베이스 (운영 환경 — PostgreSQL)
# 개발 환경은 H2 인메모리 DB를 사용하므로 아래 항목 불필요
# 운영 배포 시에만 설정
# -------------------
# DB_URL=jdbc:postgresql://localhost:5432/marketplace
# DB_USERNAME=postgres
# DB_PASSWORD=your-db-password
